# Rain Check God Terminal — Environment Variables
# Copy to .env and fill in values
# Note: No ANTHROPIC_API_KEY needed — Claude CLI uses OAuth (Max plan)

# Shared secret between Vercel frontend and VPS
AGENT_SERVER_SECRET=

# Port (default: 3848)
PORT=3848

# Tomorrow.io weather API key
TOMORROW_IO_API_KEY=

# SendGrid email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=bobby@apexai.technology

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Convex backend URL
CONVEX_URL=https://charming-marten-399.convex.cloud
