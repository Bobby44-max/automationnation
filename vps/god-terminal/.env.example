# Rain Check God Terminal — Environment Variables
# Copy to .env and fill in values

# Anthropic API key (required for SDK)
ANTHROPIC_API_KEY=

# Shared secret between Vercel frontend and VPS
AGENT_SERVER_SECRET=

# Port (default: 3848)
PORT=3848

# Tomorrow.io weather API key
TOMORROW_IO_API_KEY=

# SendGrid email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=bobby@apexai.technology

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Convex backend URL
CONVEX_URL=https://charming-marten-399.convex.cloud

# Default business ID for demo (Convex document ID)
DEFAULT_BUSINESS_ID=

# Notion API token for operations logging
NOTION_API_TOKEN=
