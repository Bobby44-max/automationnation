# ============================================================
# APEX WEATHER SCHEDULING — ENVIRONMENT VARIABLES
# ============================================================
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Convex Backend ---
CONVEX_DEPLOYMENT=                        # From: npx convex init
NEXT_PUBLIC_CONVEX_URL=                   # From: Convex dashboard → Settings → URL

# --- Clerk Auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=        # From: https://dashboard.clerk.com
CLERK_SECRET_KEY=                         # From: Clerk dashboard → API Keys
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Weather Data Providers ---
TOMORROW_IO_API_KEY=                      # From: https://www.tomorrow.io/weather-api/
OPENWEATHERMAP_API_KEY=                   # Fallback: https://openweathermap.org/api

# --- SMS Notifications (Twilio) ---
TWILIO_ACCOUNT_SID=                       # From: https://console.twilio.com
TWILIO_AUTH_TOKEN=                        # From: Twilio console → Account Info
TWILIO_PHONE_NUMBER=                      # From: Twilio console → Phone Numbers

# --- Email Notifications (SendGrid) ---
SENDGRID_API_KEY=                         # From: https://sendgrid.com
SENDGRID_FROM_EMAIL=weather@yourdomain.com

# --- Stripe Billing ---
STRIPE_SECRET_KEY=                        # From: https://dashboard.stripe.com
STRIPE_WEBHOOK_SECRET=                    # From: Stripe webhooks page
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=       # From: Stripe dashboard → API Keys

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
