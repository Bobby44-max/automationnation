# ============================================================
# APEX WEATHER SCHEDULING — ENVIRONMENT VARIABLES
# ============================================================
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Convex Backend ---
# Get from: npx convex init → Dashboard → Settings
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# --- Clerk Authentication ---
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# --- Weather Data Providers ---
# Tomorrow.io (primary): https://www.tomorrow.io/weather-api/ (500 free/day)
TOMORROW_IO_API_KEY=
# OpenWeatherMap (fallback): https://openweathermap.org/api (1000 free/day)
OPENWEATHERMAP_API_KEY=

# --- SMS Notifications (Twilio) ---
# Get from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Email Notifications (SendGrid) ---
# Get from: https://sendgrid.com → Settings → API Keys (100 free/day)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=weather@yourdomain.com

# --- Local AI (Ollama) ---
# Runs locally — no API key needed
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- n8n Workflow Orchestration ---
# Your self-hosted n8n instance URL
N8N_WEBHOOK_BASE_URL=http://localhost:5678

# --- Stripe Payments ---
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
